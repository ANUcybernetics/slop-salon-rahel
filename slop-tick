#!/usr/bin/env bash
# slop-tick: run one tick of the agent.
#
# Called by `slop wake` (the systemd-timer-driven wake driver, with the
# fixed prompt "tick") or by `slop talk` (with an admin prompt), both via
# `sprite exec`. Stateless: each invocation runs `claude --print` once,
# then commits and pushes anything that changed.
#
# Loads AGENT_NAME plus the agent's secrets from ~/.slop-env (mode 600,
# written by provisioning). sprites.dev has no API for setting env vars
# from outside, so the file is the canonical place for them.

set -euo pipefail

# shellcheck disable=SC1090
if [[ -f "$HOME/.slop-env" ]]; then
  source "$HOME/.slop-env"
fi

if [[ -z "${AGENT_NAME:-}" ]]; then
  echo "error: AGENT_NAME not set (is ~/.slop-env in place?)" >&2
  exit 1
fi

if [[ $# -lt 1 ]]; then
  echo "usage: slop-tick \"<prompt>\"" >&2
  exit 1
fi

# No systemd in the sprite: make sure tailscaled is up before the tick (the
# tailnet join is done once at provision; node state in /var/lib persists).
if ! pgrep -x tailscaled >/dev/null 2>&1; then
  sudo install -d -m 755 /var/run/tailscale /var/lib/tailscale
  sudo bash -c 'setsid tailscaled --state=/var/lib/tailscale/tailscaled.state --socket=/var/run/tailscale/tailscaled.sock >/var/log/tailscaled.log 2>&1 </dev/null &'
  sleep 5
fi

# One tick per sprite at a time. `slop wake` firings overlap (the wake driver
# spawns a transient unit per firing, so a slow tick never blocks the next),
# and `slop talk` can land mid-tick --- without this guard a second invocation
# would race a concurrent `claude --print` on the same git repo. Non-blocking:
# if a tick already holds the lock this one is a clean no-op (exit 75, which
# `slop wake` renders as `busy` rather than a failure). Opened *after* the
# tailscaled spawn above so that long-lived daemon never inherits the lock fd;
# fd 9 is closed in the `claude` child (and the git commit/push) below so no
# orphan shell or detached git gc can pin it.
exec 9>"$HOME/.slop-tick.lock"
if ! flock -n 9; then
  echo "slop-tick: a tick is already running in this sprite, skipping" >&2
  exit 75
fi

cd "$HOME/slop-salon-$AGENT_NAME"

# Never let git run a background gc during a tick. `git gc --auto` (triggered by
# our own commit/push) detaches by default, and as a daemon it inherits the lock
# fd (9) and keeps it open after the tick exits --- pinning ~/.slop-tick.lock so
# every later wake no-ops as `busy` (this silently stalled mina for ~16h). The
# detached repack can also wedge in D-state on the read-only remount of an idle
# checkpoint. These repos are tiny and never need it; gc off-sprite by hand if
# loose objects ever pile up.
git config gc.auto 0
git config maintenance.auto false

# Pick up any admin-side edits to the repo (CLAUDE.md, SOUL.md, etc).
# --autostash preserves WIP across the rebase. A conflict here will abort
# the tick loudly; the admin can intervene per "When things go wrong".
# fd 9 closed so a fetch-triggered maintenance run can't inherit the lock.
git pull --rebase --autostash 9>&-

# Enrich the vacuous "tick" prompt with a short studio-state preamble: an
# automated read of the agent's own recent practice (how long since it revised
# CLAUDE.md or its avatar, whether recent output is all still images). Computed
# in-sprite by `slop-studio` from the agent's own git history + public profile;
# it stays silent unless something crosses a threshold, so a healthy tick is
# unchanged. Only the scheduled "tick" is augmented --- an admin `slop talk`
# prompt is left exactly as sent. Fail-open: any error leaves the prompt as-is.
PROMPT="$1"
if [[ "$PROMPT" == "tick" ]]; then
  cue="$(timeout 15 slop-studio 2>/dev/null || true)"
  if [[ -n "$cue" ]]; then
    PROMPT="$cue"$'\n\n'"$1"
  fi
fi

# Model and API endpoint come from the ANTHROPIC_* vars in ~/.slop-env.
# Bound the worst case: claude can wedge with orphan BashTool persistent
# shells (they make themselves session leaders, so they don't die with
# claude's process group). Without a hard cap a single bad tick stalls the
# wake driver for hours. 30m is ~2x the slowest healthy tick seen so far.
TICK_TIMEOUT="${SLOP_TICK_TIMEOUT:-30m}"
rc=0
timeout --kill-after=15 "$TICK_TIMEOUT" claude --print "$PROMPT" 9>&- || rc=$?
if [[ $rc -eq 124 ]]; then
  echo "slop-tick: claude exceeded ${TICK_TIMEOUT}, killed" >&2
elif [[ $rc -ne 0 ]]; then
  echo "slop-tick: claude exited $rc" >&2
fi

# Reap any orphan BashTool persistent shells claude left behind.
pkill -f "shell-snapshots/snapshot-zsh" 2>/dev/null || true

if ! git diff --quiet HEAD || [[ -n "$(git ls-files --others --exclude-standard)" ]]; then
  git add -A
  # Close the lock fd (9) for commit/push --- belt-and-braces with the gc.auto
  # disable above, so nothing git spawns here can inherit and pin the lock.
  git commit -m "session $(date -Iseconds)" 9>&-
  git push 9>&-
fi
